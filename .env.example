# ============================================
# TeamSpeak 3 - ServerQuery Configuration
# ============================================
TS3_HOST=127.0.0.1
TS3_QUERY_PORT=10011
TS3_USERNAME=serveradmin
TS3_PASSWORD=your_ts3_password
TS3_SERVER_ID=1

# ============================================
# TeamSpeak 6 - ServerQuery Configuration
# ============================================
# TS6 uses HTTP-based ServerQuery on port 10080
# and/or SSH-based ServerQuery on port 10022
TS6_HOST=127.0.0.1
TS6_QUERY_PORT=10080
TS6_SSH_PORT=10022
TS6_USERNAME=serveradmin
TS6_PASSWORD=your_ts6_password
TS6_API_KEY=your_ts6_api_key
TS6_SERVER_ID=1

# ============================================
# Connect Addresses (for "Join server" buttons)
# ============================================
# These are the public addresses users connect to
# (may differ from query HOST addresses above)
TS3_CONNECT_ADDRESS=ts3.example.com
TS6_CONNECT_ADDRESS=ts6.example.com

# ============================================
# Web Server Configuration
# ============================================
WEB_PORT=5540
LOGO_URL=https://alleria.pl/images/logo-clr.png

# Language: PL / EN
LANGUAGE=PL

# Set to 'true' if behind a reverse proxy (nginx, etc.)
TRUST_PROXY=false
